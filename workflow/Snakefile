        #geo  = lambda wc: all_hrf_files(wc)["geo"]    # geometric pos and landmarks
    output:
        get_groupavg_imagerecon_output()
    params:
        cfg_img_recon = config['image_recon'],
        cfg_dataset = config['dataset']