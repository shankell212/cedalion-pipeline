def get_optional_input(SB_flag):
    if SB_flag:
        return join(ROOT, 'derivatives', 'cedalion', 'forward', config['image_recon']['generate_sensitivity']['sub_folder'], 'sbf.nc')
    else:
        return [] # Return an empty list if the input is not needed


rule imagerecon:
    input:
        hrf_data = rules.hrf_estimation.output.net_hrf,
        Adot = ancient(rules.generate_sensitivity.output.Adot),
        SB = get_optional_input(config['image_recon']['spatial_basis']['enable']),
    output:
        get_imagerecon_output()
    params:
        cfg_img_recon = config['image_recon'],
        cfg_hrf = config['hrf_estimation'],
        root_dir = ROOT,
        derivatives_subfolder = config['dataset']['derivatives_subfolder']
    script:
        #"scripts/image_recon.py"
        SNAKEFILE_DIR / "scripts/image_recon.py"
      

def all_img_files(wc):
    ''' Return a list of all img files for this subject and task (i.e. all subs)'''  
    img_paths =  [
        (
        f"{SAVE_DIR}/image_results/sub-{subject}/"
        f"Xs_sub-{subject}_{wc.task}"
        f"_cov_alpha_spatial_{config['image_recon']['alpha_spatial']}"
        f"_alpha_meas_{config['image_recon']['alpha_meas']}"
        + (f"_recon_mode_{config['image_recon']['recon_mode']}")
        + ("_Cmeas" if config["image_recon"]["Cmeas"]["enable"] else "_noCmeas")
        + ("_SB" if config["image_recon"]["spatial_basis"]["enable"] else "_noSB")
        + ("_mag" if config["image_recon"]["mag"]["enable"] else "_ts")
        + (f"_{config['image_recon']['mag']['t_win'][0]}_{config['image_recon']['mag']['t_win'][1]}" if config["image_recon"]["mag"]["enable"] else "")
        + ".nc"
    )
        for subject in config["dataset"]["subject"]
    ]
    return {
        "image":  img_paths,
    }        

use rule groupaverage as groupaverage_imgspace with:
    input:
        hrf_subs = lambda wc: all_img_files(wc)["image"],  # img data from all subs for this task
