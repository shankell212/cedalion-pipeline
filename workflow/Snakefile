# Allow overriding root directory from command line with --config root_dir=path
ROOT = config.get('root_dir', config['dataset']["root_dir"])
if not config['dataset']["derivatives_subfolder"]:   # if derivatives_subfolder is not specified in config, set to empty string to avoid issues with path construction
    config['dataset']["derivatives_subfolder"] = '' 
DERIV = config.get('deriv_dir', config['dataset']["derivatives_subfolder"])
SAVE_DIR = join(ROOT, 'derivatives', 'cedalion', DERIV)

# Get subject list from BIDS directory, excluding any subjects in the exclude list in config
dirs = os.listdir(ROOT) 
subject_list = [d.replace("sub-", "") for d in dirs if "sub" in d and d.replace("sub-", "") not in config["dataset"]["subjects_to_exclude"]]
config["dataset"]["subject"] = subject_list
config["dataset"]["run"] = [f"{i:02d}" for i in range(1, int(config["dataset"]["num_runs"]) + 1)]

def get_imagerecon_output(): # create file name for image recon output
    return (
        f"{SAVE_DIR}/image_results/sub-{{subject}}/"
        f"Xs_sub-{{subject}}_{{task}}"
        f"_cov_alpha_spatial_{config['image_recon']['alpha_spatial']}"
        f"_alpha_meas_{config['image_recon']['alpha_meas']}"
        + (f"_recon_mode_{config['image_recon']['recon_mode']}")
        + ("_Cmeas" if config["image_recon"]["Cmeas"]["enable"] else "_noCmeas")
        + ("_SB" if config["image_recon"]["spatial_basis"]["enable"] else "_noSB")
        + ("_mag" if config["image_recon"]["mag"]["enable"] else "_ts")
        + (f"_{config['image_recon']['mag']['t_win'][0]}_{config['image_recon']['mag']['t_win'][1]}" if config["image_recon"]["mag"]["enable"] else "")
        + ".nc"
    )

def get_groupavg_imagerecon_output():
    return (
        f"{SAVE_DIR}/group_results/"
        f"Xs_groupavg_{{task}}"
        f"_cov_alpha_spatial_{config['image_recon']['alpha_spatial']}"
        f"_alpha_meas_{config['image_recon']['alpha_meas']}"
        + (f"_recon_mode_{config['image_recon']['recon_mode']}")
        + ("_Cmeas" if config["image_recon"]["Cmeas"]["enable"] else "_noCmeas")
        + ("_SB" if config["image_recon"]["spatial_basis"]["enable"] else "_noSB")
        + ("_mag" if config["image_recon"]["mag"]["enable"] else "_ts")
        + (f"_{config['image_recon']['mag']['t_win'][0]}_{config['image_recon']['mag']['t_win'][1]}" if config["image_recon"]["mag"]["enable"] else "")
        + ".nc"
    )


def get_hrf_output():
    return (
        f"{SAVE_DIR}/hrf_estimate/sub-{{subject}}/"
        f"sub-{{subject}}_task-{{task}}_nirs_hrf_estimate_{config['hrf_estimation']['rec_str']}.nc"
    )

rule all_default:
    input:
        # Groupaverage channel space 
        [expand(
            f"{SAVE_DIR}/group_results/"
            f"task-{{task}}_nirs_groupaverage_chanspace_{config['hrf_estimation']['rec_str']}.nc",
            task=config["dataset"]["task"],
        ),

        # Groupaverage image space
        expand(
            get_groupavg_imagerecon_output(),
            task=config["dataset"]["task"],
        )]


rule all_groupavg_imagerecon:
    input:
        expand(get_groupavg_imagerecon_output(), task=config["dataset"]["task"])


rule all_preprocess:
    input:
        expand([
            (f"{SAVE_DIR}/preprocessed_data/sub-{{subject}}/sub-{{subject}}_task-{{task}}_run-{{run}}_nirs_preprocessed.nc"),  #  preprocessed_dataessed snirf
            (f"{SAVE_DIR}/preprocessed_data/sub-{{subject}}/sub-{{subject}}_task-{{task}}_run-{{run}}_nirs_dataquality_geo.sidecar"), # data qual sidecar 
            ],
            subject = config["dataset"]["subject"],
            task = config["dataset"]["task"],
            run = config["dataset"]["run"]
            )
        
rule all_hrf_estimation:
    input:
        expand([
            get_hrf_output(),
            #(f"{SAVE_DIR}/hrf_estimate/sub-{{subject}}/sub-{{subject}}_task-{{task}}_nirs_dataquality.json"),  # blockaverage dataqual
            #(f"{SAVE_DIR}/hrf_estimate/sub-{{subject}}/sub-{{subject}}_task-{{task}}_nirs_geo.sidecar")
            ],
            subject = config["dataset"]["subject"],
            task = config["dataset"]["task"],
            )      
                      
rule all_groupaverage:
    input:
        expand([  
            (f"{SAVE_DIR}/group_results/task-{{task}}_nirs_groupaverage_chanspace_{config['hrf_estimation']['rec_str']}.nc") # groupaverage
            ],
            task = config["dataset"]["task"],
            )      
            
rule all_imagerecon:
    input:
        expand(get_imagerecon_output(), subject = config["dataset"]["subject"], task=config["dataset"]["task"])

if config['image_recon']['spatial_basis']['enable']: # run generate sbf rule if enable is true
    rule all_generate_sbf:
        input:
            join(ROOT, 'derivatives', 'cedalion', 'forward', config['image_recon']['generate_sensitivity']['sub_folder'], 'sbf.nc')

rule preprocess:
    input:
        # raw .snirf and events.tsv
        snirf = f"{ROOT}/sub-{{subject}}/nirs/sub-{{subject}}_task-{{task}}_run-{{run}}_nirs.snirf",
        events = f"{ROOT}/sub-{{subject}}/nirs/sub-{{subject}}_task-{{task}}_run-{{run}}_events.tsv",
        module1 = SNAKEFILE_DIR / "scripts/modules/module_preprocess.py",
        module2 = SNAKEFILE_DIR / "scripts/modules/module_plot_DQR.py"
    output:
        snirf = (f"{SAVE_DIR}/preprocessed_data/sub-{{subject}}/sub-{{subject}}_task-{{task}}_run-{{run}}_nirs_preprocessed.snirf"), # preprocessed snirf
        sidecar = (f"{SAVE_DIR}/preprocessed_data/sub-{{subject}}/sub-{{subject}}_task-{{task}}_run-{{run}}_nirs_dataquality.nc"), # data qual sidecar
    params:
        cfg_preprocess = config['preprocess'],
        root_dir = ROOT,
        derivatives_subfolder = config['dataset']['derivatives_subfolder'],
        stim_lst = config['hrf_estimation']['stim_lst'],
        mse_amp_thresh = config['groupaverage']['mse']['mse_amp_thresh']
    script:
        SNAKEFILE_DIR / "scripts/preprocess.py"



def all_preprocessed_runs(wc):
    ''' Return a list of all preprocessed .snirf files for this subject and task (i.e. all runs)'''  
    
    run_paths =  [
        f"{SAVE_DIR}/preprocessed_data/sub-{wc.subject}/"
        f"sub-{wc.subject}_task-{wc.task}_run-{run}_nirs_preprocessed.snirf"
        for run in config["dataset"]["run"]
    ]
    data_quality_paths = [
        f"{SAVE_DIR}/preprocessed_data/sub-{wc.subject}/"
        f"sub-{wc.subject}_task-{wc.task}_run-{run}_nirs_dataquality.nc"
        for run in config["dataset"]["run"]
    ]
    return {
        "preproc":  run_paths,
        "quality":  data_quality_paths
    }
    

rule hrf_estimation:
    input:
        preproc  = lambda wc: all_preprocessed_runs(wc)["preproc"],
        quality  = lambda wc: all_preprocessed_runs(wc)["quality"],
        module3 = SNAKEFILE_DIR / "scripts/modules/module_hrf_est.py",
    output:
        # HRF for each task
        net_hrf = get_hrf_output(),
    params:
        cfg_hrf = config['hrf_estimation'],
    script:
        SNAKEFILE_DIR / "scripts/hrf_estimation.py"
    
    

def all_hrf_files(wc):
    ''' Return a list of all hrf files for this subject+task (i.e. all subs)'''  
    
    hrf_paths =  [
        f"{SAVE_DIR}/hrf_estimate/sub-{subject}/sub-{subject}_task-{wc.task}_nirs_hrf_estimate_{config['hrf_estimation']['rec_str']}.nc" 
        for subject in config["dataset"]["subject"]
    ]

    return {
        "hrf":  hrf_paths,
        # "geo": geo_paths
    }
    


rule groupaverage:
    input: 
        hrf_subs  = lambda wc: all_hrf_files(wc)["hrf"], # block avg data
    output:
        # group averaged data
        (f"{SAVE_DIR}/group_results/task-{{task}}_nirs_groupaverage_chanspace_{config['hrf_estimation']['rec_str']}.nc")   
    params:
        cfg_groupaverage = config["groupaverage"],
        cfg_dataset = config['dataset'],
        cfg_hrf = config['hrf_estimation'],
        flag_prune_channels = config['preprocess']['steps']['prune']['enable'],
    script:
        SNAKEFILE_DIR / "scripts/groupaverage.py"
        #"scripts/groupaverage.py"
        

